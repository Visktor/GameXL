{
  "name": "GameXL",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @GameXL/db db:push",
    "db:studio": "turbo -F @GameXL/db db:studio",
    "db:generate": "turbo -F @GameXL/db db:generate",
    "db:migrate": "turbo -F @GameXL/db db:migrate",
    "db:start": "turbo -F @GameXL/db db:start",
    "db:watch": "turbo -F @GameXL/db db:watch",
    "db:stop": "turbo -F @GameXL/db db:stop",
    "db:down": "turbo -F @GameXL/db db:down",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "husky",
    "typecheck": "turbo check-types",
    "typecheck:web": "turbo -F web check-types",
    "typecheck:server": "turbo -F server check-types",
    "generate": "turbo -F @GameXL/db db:generate"
  },
  "dependencies": {
    "@GameXL/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@GameXL/config": "workspace:*",
    "@biomejs/biome": "2.4.10",
    "@types/node": "^22.13.14",
    "husky": "latest",
    "lint-staged": "latest",
    "turbo": "^2.8.12",
    "typescript": "^5",
    "ultracite": "7.4.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
      "pnpm dlx ultracite fix"
    ]
  },
  "packageManager": "pnpm@10.2.0"
}
