model User {
  id              String     @id
  name            String
  email           String
  emailVerified   Boolean    @default(false)
  image           String?
  username        String?
  displayUsername String?    @map("display_username")
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  sessions        Session[]
  accounts        Account[]
  userGames       UserGame[]
  reviews         Review[]

  @@unique([email])
  @@unique([username])
  @@map("user")
}
